# ==========================================
# 🐍 Python & Geliştirme Ortamı
# ==========================================
__pycache__/
*.py[cod]
*$py.class
.venv/
.venv-*/
.conda-*/
.env
.pytest_cache/
.coverage
.mypy_cache/
.ipynb_checkpoints/
*.egg-info/
dist/
build/
*.log

# ==========================================
# 🖥️ IDE & Sistem Dosyaları
# ==========================================
.DS_Store
Thumbs.db
.vscode/
.idea/
.agents/
.cursorignore
.cursorrules

# ==========================================
# 📊 Veri (Data) - Sadece Tanımları Tutalım
# ==========================================
# Tüm veri klasörlerini kapat
data/*/

# Ama manifests ve experiments içindeki kodları aç
!data/manifests/
!data/manifests/data_locations.md
!data/manifests/data_contract.json
!data/experiments/
!data/experiments/README.md
!data/experiments/*.py

# ==========================================
# 📝 Raporlar ve Çıktılar (Outputs)
# ==========================================
# Klasörleri kapat
reports/*/

# Ama rapor şablonlarını ve markdown dosyalarını gönderelim
!reports/
!reports/*.md
!reports/**/*.md

# Büyük figür ve tablo çıktılarını tekrar yasakla (garantiye alalım)
reports/**/*.pdf
reports/**/*.png
reports/**/*.tsv
*.manifest.json
