# ==========================================
# 📝 Raporlar ve Çıktılar (Testler İçin Açıldı)
# ==========================================
# Sadece bu üç klasörün gitmesine izin veriyoruz (Testler ve jüri için)
!reports/core_tables/
!reports/core_figures/
!reports/release/

# Ama bu klasörler içindeki büyük geçici dosyalar (varsa) yine de gitmesin
reports/**/*.log
reports/**/*.tmp
reports/.cache/

# Jürinin okuyacağı markdown ve küçük tabloları açalım
!reports/**/*.md
!reports/**/*.tsv
!reports/**/*.png
!reports/reviewer_pack/
